#!/bin/bash

{{ $sudo := "sudo " -}}
{{ if eq .chezmoi.username "root" -}}
{{   $sudo = "" -}}
{{ end -}}

set -eufo pipefail

{{ $sudo }}apt-get update

{{ range .packages.linux.apt.common }}
{{ $sudo }}apt-get install -y {{ . | quote }}
{{ end -}}

{{ range .packages.linux.npm.common }}
npm install -g {{ . | quote }} --no-package-lock
{{ end -}}