#!/bin/bash
set -euo pipefail

# Configuration
TARGET_SECRETS_FILE="$HOME/.local/share/chezmoi/.chezmoidata/secrets.yml"

# Edit this template to add/remove secrets.
# Don't add quotes around fetch_secret calls below.
# fetch_secret returns strings from Bitwarden that *include double quotes*.
# Those quotes will be written to the YAML below to quote the string.
generate_config() {
    local output_file="$1"
    cat <<EOF > "$output_file"
# Dotfiles Secrets
#
# This file is installed and managed by the dotfiles-secrets script.
# Check if secrets are installed in templates with {{ if hasKey . "secrets" }}.
# Reference secrets like {{ .secrets.ssh.personal_config }}.
#
# DO NOT commit this file to git.

secrets:
  data:
$(fetch_secret_yaml '35956e2c-d99e-4d3e-a784-b4200150ee2a')
  ssh:
    work_config: $(fetch_secret 'b4770e5d-94e5-46b8-87ef-b29c0101dabe' '.notes')
    personal_config: $(fetch_secret '149eb0d7-ebbd-46f0-8f25-b3370151e70a' '.notes')
EOF
}

usage() {
    echo "Usage: $(basename "$0") [install|diff|help]"
    echo ""
    echo "Commands:"
    echo "  install   (default) Fetch secrets and write to target file."
    echo "  diff      Fetch secrets and show diff against existing target file."
    echo "  help      Show this help message."
}

log_info()    { echo -e "ℹ️  $1" >&2; }
log_success() { echo -e "✅  $1" >&2; }
log_error()   { echo -e "❌  $1" >&2; }

check_deps() {
    if ! command -v bw &> /dev/null; then
        log_error "Bitwarden CLI (bw) is required but not found."
        exit 1
    fi
    if ! command -v jq &> /dev/null; then
        log_error "jq is required but not found."
        exit 1
    fi
}

# Fetch secret note. Returns a JSON-quoted string (including surrounding quotes).
fetch_secret() {
    log_info "Fetching Bitwarden item $1..."
    bw get item "$1" | jq "$2"
}

# Fetch a YAML note and indent its lines by 4 spaces for embedding under a YAML key.
fetch_secret_yaml() {
    log_info "Fetching Bitwarden item $1..."
    bw get item "$1" | jq -r '.notes' | sed 's/^/    /'
}

main() {
    local cmd="${1:-install}"

    case "$cmd" in
        help|-h|--help)
            usage
            exit 0
            ;;
        install|diff)
            ;;
        *)
            log_error "Unknown command: $cmd"
            usage
            exit 1
            ;;
    esac

    check_deps

    if ! bw login --check &> /dev/null; then
        log_error "Not logged in to Bitwarden. Run 'bw login' first."
        exit 1
    fi

    if ! bw unlock --check &> /dev/null; then
        log_info "Vault is locked. Unlocking..."
        BW_SESSION="$(bw unlock --raw)"
        export BW_SESSION
    fi

    bw sync

    tmp_file=$(mktemp)
    trap 'rm -f "$tmp_file"' EXIT

    generate_config "$tmp_file"

    if [[ "$cmd" == "diff" ]]; then
        if [[ -f "$TARGET_SECRETS_FILE" ]]; then
            diff "$TARGET_SECRETS_FILE" "$tmp_file" || true
        else
            log_info "No existing secrets file found."
            cat "$tmp_file"
        fi
    else
        mkdir -p "$(dirname "$TARGET_SECRETS_FILE")"
        cp "$tmp_file" "$TARGET_SECRETS_FILE"
        chmod 600 "$TARGET_SECRETS_FILE"
        log_success "Secrets installed to $TARGET_SECRETS_FILE"
    fi
}

main "$@"
